APP_HOST=127.0.0.1
APP_PORT=8000
DATABASE_PATH=backend/traffic_violations.db
CAPTURE_DIR=captured_violations

# Camera source: 0 for webcam, sample_videos/test.mp4 for a file, or an RTSP/IP camera URL.
CAMERA_SOURCE=0

# YOLO weights. Replace these with your trained helmet/signal models when available.
VEHICLE_MODEL=models/yolov8n.pt
HELMET_MODEL=models/helmet_yolov8.pt
SIGNAL_MODEL=

# Detection tuning.
CONFIDENCE_THRESHOLD=0.35
VIOLATION_COOLDOWN_SECONDS=8

# Sensor integration. Use serial for final hardware, or disabled while installing/testing UI only.
SENSOR_MODE=serial
SERIAL_PORT=COM3
SERIAL_BAUDRATE=9600

# Notification provider: textbelt, twilio, fast2sms, or none while credentials are pending.
NOTIFICATION_PROVIDER=textbelt
VIOLATOR_PHONE=+910000000000

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

FAST2SMS_API_KEY=
FAST2SMS_SENDER_ID=FSTSMS

# Textbelt free key allows limited testing, usually 1 SMS/day.
TEXTBELT_API_KEY=textbelt
